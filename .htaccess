# Kadrivo – Vereins-Pfad-Routing
# kadrivo.de/<vereinsname> laedt die App; die App liest den Verein aus dem Pfad.
# Echte Dateien und Ordner werden normal ausgeliefert.

# ----------------------------------------------------------------
# LiteSpeed-Cache (LSCache) fuer App-Shell-Dateien deaktivieren.
# Ohne das liefert Hostinger/LiteSpeed nach einem Deploy weiterhin
# alte Versionen von index.html/app.js/app.css/service-worker.js aus,
# auch wenn die Dateien auf dem Server bereits aktualisiert wurden.
# ----------------------------------------------------------------
<IfModule LiteSpeed>
  CacheLookup off
</IfModule>

<FilesMatch "^(index\.html|backend\.html|taktikboard-2d\.html|taktikboard-3d\.html|service-worker\.js|manifest\.webmanifest|manifest\.php)$">
  <IfModule mod_headers.c>
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
    Header unset X-LiteSpeed-Cache-Control
  </IfModule>
  <IfModule LiteSpeed>
    CacheLookup off
  </IfModule>
</FilesMatch>

<FilesMatch "\.(js|css)$">
  <IfModule mod_headers.c>
    Header set Cache-Control "no-cache, must-revalidate"
  </IfModule>
</FilesMatch>

RewriteEngine On

# HTTPS erzwingen
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]

# Vereins-spezifisches Manifest: /<slug>/manifest.webmanifest → manifest.php?slug=<slug>
RewriteRule ^([a-z0-9-]+)/manifest\.webmanifest$ manifest.php?slug=$1 [L,QSA]

# Wurzel-Manifest auf manifest.php
RewriteRule ^manifest\.webmanifest$ manifest.php [L]

# Vorhandene Dateien direkt ausliefern (js, css, Bilder, Taktikboards, etc.)
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Alles andere (z.B. /vfl-biedenkopf) auf index.html umschreiben.
# Die URL im Browser bleibt erhalten; die App ermittelt den Verein aus dem Pfad.
RewriteRule ^ index.html [L]
